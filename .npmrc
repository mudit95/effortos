# Sentry's @sentry/nextjs v9 peer range lags behind Next.js releases
# (latest 9.x declares ^13 || ^14 || ^15.0.0-rc.0, which npm won't match
# against our Next 16.2.x). The Sentry runtime itself is compatible — only
# the declared peer range is stale. Vercel's production install uses strict
# peer resolution by default, so we relax it here to unblock builds.
#
# Reassess once Sentry publishes a release that formally lists Next 16
# in its peer range — then this file can be deleted.
legacy-peer-deps=true
